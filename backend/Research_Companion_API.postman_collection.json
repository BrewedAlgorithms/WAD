				{
					"name": "Upload Paper",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}"
							}
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "file",
									"type": "file",
									"src": []
								},
								{
									"key": "metadata",
									"value": "{\n  \"title\": \"Attention Is All You Need\",\n  \"abstract\": \"The dominant sequence transduction models are based on complex recurrent or convolutional neural networks that include an encoder and a decoder. The best performing models also connect the encoder and decoder through an attention mechanism. We propose a new simple network architecture, the Transformer, based solely on attention mechanisms, dispensing with recurrence and convolutions entirely.\",\n  \"keywords\": [\"Transformer\", \"attention mechanism\", \"self-attention\", \"sequence transduction\", \"machine translation\", \"encoder-decoder\"],\n  \"authors\": [\"Ashish Vaswani\", \"Noam Shazeer\", \"Niki Parmar\", \"Jakob Uszkoreit\", \"Llion Jones\", \"Aidan N. Gomez\", \"Łukasz Kaiser\", \"Illia Polosukhin\"],\n  \"journalName\": \"Conference on Neural Information Processing Systems (NIPS 2017)\",\n  \"publication_date\": \"2017\",\n  \"detailed_summary\": \"This paper introduces the Transformer, a novel network architecture for sequence transduction tasks that completely eschews recurrence and convolutions, relying solely on attention mechanisms.\",\n  \"paperLink\": \"https://arxiv.org/abs/1706.03762\",\n  \"gemini_analysis\": {\n    \"research_area\": \"Natural Language Processing and Deep Learning\",\n    \"methodology\": \"Proposal and evaluation of a novel neural network architecture, the Transformer, which is based entirely on attention mechanisms.\",\n    \"key_findings\": [\n      \"The Transformer model achieves state-of-the-art results on machine translation tasks\",\n      \"The architecture is significantly more parallelizable than recurrent models\",\n      \"By relying solely on self-attention, the model can effectively learn long-range dependencies\"\n    ],\n    \"limitations\": [\n      \"The paper does not explicitly state limitations of the proposed model\",\n      \"The model architecture lacks any inherent understanding of sequence order\"\n    ],\n    \"research_impact\": \"This paper is foundational in modern NLP. The introduction of the Transformer architecture marked a paradigm shift away from recurrent models towards fully attention-based models.\",\n    \"future_directions\": []\n  },\n  \"confidence_score\": 0.95\n}",
									"type": "text"
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/papers/upload",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"papers",
								"upload"
							]
						},
						"description": "Upload a new research paper with optional metadata. The metadata field is optional - if not provided, the system will use basic file information. For metadata extraction, use the separate endpoint: POST /api/v1/papers/metadatafromai (requires authentication)"
					},
					"response": []
				},
