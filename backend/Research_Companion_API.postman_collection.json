				{
					"name": "Extract Metadata from PDF",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "file",
									"type": "file",
									"src": []
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/papers/metadatafromai",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"papers",
